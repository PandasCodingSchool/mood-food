PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moodfood
DB_USER=postgres
DB_PASSWORD=your_password

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=30000

# Swiggy proxy (forwards /api/swiggy/* to the intelligence service)
SWIGGY_TIMEOUT_MS=25000

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AI=10