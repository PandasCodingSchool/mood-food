PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moodfood
DB_USER=postgres
DB_PASSWORD=your_password

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=90000

# Swiggy proxy (forwards /api/swiggy/* to the intelligence service)
SWIGGY_TIMEOUT_MS=25000

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AI=10

# Swiggy token encryption key (32 bytes base64)
SWIGGY_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key-here
SWIGGY_OAUTH_REDIRECT_URI=https://moodfood.fun/api/swiggy/oauth/callback
FRONTEND_ORIGIN=https://moodfood.fun
# Personalization signals spine
RATE_LIMIT_SIGNALS=120
# Shared secret with the intelligence service for the replay feed (must match SYNC_KEY there)
INTELLIGENCE_SYNC_KEY=
LEARN_TIMEOUT_MS=8000
