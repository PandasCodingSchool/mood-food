OPENAI_API_KEY=sk-...

# --- Swiggy MCP (Food server) ---
# Streamable-HTTP MCP endpoint. Docs: https://mcp.swiggy.com/builders
SWIGGY_MCP_URL=https://mcp.swiggy.com/food
# Phase 1: a single service/bootstrap account token (OAuth'd once) that powers
# discovery. Tokens last ~5 days with no refresh in v1 — re-auth via an ops job.
SWIGGY_BOOTSTRAP_TOKEN=
# Runtime token store. `python -m scripts.swiggy_auth --save` writes a fresh
# token here and the running service picks it up on the next request (no restart).
# A valid token here takes precedence over SWIGGY_BOOTSTRAP_TOKEN.
SWIGGY_TOKEN_FILE=swiggy_token.json
# JSON map of lowercase city -> the bootstrap account's saved Swiggy addressId.
# e.g. {"bangalore":"addr_123","mumbai":"addr_456"}
SWIGGY_CITY_ADDRESS_MAP={}
# Default city used when the caller doesn't pass one.
SWIGGY_DEFAULT_CITY=
# false (default) = user address not retrieved yet; once city map/default city
# lookups are exhausted, resolve_address_id raises SwiggyAddressRequiredError
# instead of calling get_addresses live. Set true to allow the live lookup.
SWIGGY_ADDRESS_RETRIEVAL_ENABLED=false
# MCP call resiliency (ship-to-production guidance: 500ms base, max 4 attempts).
SWIGGY_MAX_RETRIES=4
SWIGGY_RETRY_BASE_MS=500
SWIGGY_TIMEOUT_S=20

# --- Learning / personalization layer ---
# SQLite model store for learned per-user state (rebuildable cache).
MODEL_STORE_PATH=model_store.db
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256
# Shared secret with the Node backend for the signals replay feed.
SYNC_KEY=
NODE_BASE_URL=http://localhost:3001
